{
  "name": "reelink",
  "version": "0.0.0",
  "description": "Reelink: video-as-state MCP server for AI coding agents. Records browser sessions as timestamp-aligned state packages and re-links them to your code.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "reelink": "./dist/cli.js",
    "reelink-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "NOTICE",
    "THIRD_PARTY_LICENSES.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postinstall": "bunx playwright install chromium || true",
    "smoketest:recording": "bun run scripts/generate-playwright-fixture.ts",
    "smoketest:ffmpeg": "bun run scripts/smoketest-ffmpeg.ts",
    "smoketest:gateway": "bun run scripts/smoketest-gateway.ts",
    "smoketest:logger": "bun run scripts/smoketest-logger.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.8.1",
    "ai": "^6.0.0",
    "ffmpeg-static": "^5.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.49.0",
    "react-grab": "^0.1.31",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
