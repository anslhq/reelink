{
  "name": "@anslai/reck",
  "version": "0.0.0",
  "description": "Reck: video-as-state MCP server for AI coding agents. Records browser sessions as timestamp-aligned state packages and links them to your code.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "reck": "./dist/cli.js",
    "reck-mcp": "./dist/server.js"
  },
  "homepage": "https://tryreck.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anslhq/reck.git"
  },
  "bugs": {
    "url": "https://github.com/anslhq/reck/issues"
  },
  "files": [
    "dist",
    "NOTICE",
    "THIRD_PARTY_LICENSES.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build": "bunx --bun tsc -p tsconfig.json",
    "dev": "bun run src/server.ts",
    "typecheck": "bunx --bun tsc -p tsconfig.test.json --noEmit",
    "test": "bun test",
    "clean": "trash dist",
    "postinstall": "bunx --bun playwright install chromium || true",
    "smoketest:recording": "bun run scripts/smoketest-recording-package.ts",
    "smoketest:ffmpeg": "bun run scripts/smoketest-ffmpeg.ts",
    "smoketest:gateway": "bun run scripts/smoketest-gateway.ts",
    "smoketest:child-gateway": "bun run scripts/smoketest-child-gateway.ts",
    "smoketest:logger": "bun run scripts/smoketest-logger.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.54",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.8.1",
    "@playwright/mcp": "^0.0.71",
    "ai": "^6.0.0",
    "ffmpeg-static": "^5.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.49.0",
    "react-grab": "^0.1.31",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
