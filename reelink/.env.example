# Primary VLM path: OpenRouter hosted Qwen VL (raw video) for Layer 0 analysis.
OPENROUTER_API_KEY=
REELINK_OPENROUTER_MODEL=qwen/qwen3.6-flash

# Secondary path: OpenAI for GPT-backed reelink_query fallback (Decision 11).
# Used ONLY when deterministic matcher returns no match. Qwen stays primary for VLM.
OPENAI_API_KEY=
REELINK_OPENAI_MODEL=gpt-5

# Optional: local LM Studio fallback for Qwen3-VL
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Reelink runtime
REELINK_LOG_LEVEL=info
